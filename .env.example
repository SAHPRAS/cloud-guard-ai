# Copy to .env and adjust. NO AWS keys go here — the instance role handles auth.

AWS_REGION=eu-central-1
PROFILE_LABEL=DT_DTRD_DEV

# Bedrock model IDs. Verify the EXACT strings in your account/region with:
#   aws bedrock list-foundation-models --region eu-central-1 \
#     --query "modelSummaries[?contains(modelId,'claude')].modelId"
#
# NOTE: in 2026 many Claude models invoke via a cross-region INFERENCE PROFILE,
# not the bare model id. For EU data residency use the eu. (Geo) profile, e.g.:
#   eu.anthropic.claude-sonnet-4-6...   /   eu.anthropic.claude-haiku-4-5...
# List profiles with:
#   aws bedrock list-inference-profiles --region eu-central-1
BEDROCK_MODEL_SONNET=eu.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_HAIKU=eu.anthropic.claude-haiku-4-5

# CUR (Cost & Usage Report) via Athena — exact-to-the-cent cost that matches
# the Bills page (Cost Explorer's NetAmortizedCost can still drift for
# EDP/private-rate discounts). Must match the region your S3 bucket + Glue
# database (cur_db) actually live in — Athena requires the query-results
# bucket to be in the same region as the query.
ATHENA_REGION=eu-central-1
ATHENA_DATABASE=cur_db
ATHENA_TABLE=aws_cur
ATHENA_OUTPUT_S3=s3://cloud-guard-ai/athena-results/

# DocumentDB connection string for the consentdb collection drill-down (Resource
# Inventory -> rds-rms-dev-db-cluster-instane-1). Never commit the real value —
# only set this in your own untracked .env.
# DOCDB_URI=mongodb://<user>:<password>@<cluster-endpoint>:27017/<database>
DOCDB_URI=
